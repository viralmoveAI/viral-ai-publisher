rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks if the document ID matches the authenticated user's ID
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper to check if a user profile indicates they are a platform admin
    function isPlatformAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Checks if the user is a member of the workspace
    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    // Fetches the workspace member document
    function getWorkspaceMember(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    // Checks if the user has specific roles in the workspace
    function hasWorkspaceRole(workspaceId, roles) {
      return isWorkspaceMember(workspaceId) &&
        getWorkspaceMember(workspaceId).data.role in roles;
    }

    // Checks if the user is the workspace owner
    function isWorkspaceOwner(workspaceId) {
      return hasWorkspaceRole(workspaceId, ['owner']);
    }

    // Checks if the user has editor/writer permissions in the workspace
    function canEditWorkspace(workspaceId) {
      return hasWorkspaceRole(workspaceId, ['owner', 'admin', 'editor', 'content_creator']);
    }

    // ─────────────────────────────────────────
    // USERS COLLECTION
    // ─────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isPlatformAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && isOwner(userId) &&
        // Prevent users from changing their own role or plan
        !('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('plan' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isPlatformAdmin();

      // User notifications subcollection
      match /notifications/{notificationId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ─────────────────────────────────────────
    // WORKSPACES COLLECTION
    // ─────────────────────────────────────────
    match /workspaces/{workspaceId} {
      allow read: if isAuthenticated() && (isWorkspaceMember(workspaceId) || isPlatformAdmin());
      // Anyone logged in can create a workspace (they automatically become the owner in the batch write)
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && hasWorkspaceRole(workspaceId, ['owner', 'admin']);
      allow delete: if isAuthenticated() && isWorkspaceOwner(workspaceId);

      // Members subcollection (Solves the chicken-and-egg problem)
      match /members/{memberId} {
        allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
        allow create: if isAuthenticated() && (
          // Allow the workspace owner to create their initial membership record
          (request.auth.uid == memberId && request.resource.data.role == 'owner') ||
          // Or allow an existing owner/admin to create a member document
          hasWorkspaceRole(workspaceId, ['owner', 'admin'])
        );
        allow update: if isAuthenticated() && hasWorkspaceRole(workspaceId, ['owner', 'admin']);
        allow delete: if isAuthenticated() && (
          // Owners and admins can remove members
          hasWorkspaceRole(workspaceId, ['owner', 'admin']) ||
          // Members can remove themselves (leave workspace)
          request.auth.uid == memberId
        );
      }

      // Posts subcollection
      match /posts/{postId} {
        allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
        allow create: if isAuthenticated() && canEditWorkspace(workspaceId);
        allow update: if isAuthenticated() && canEditWorkspace(workspaceId);
        allow delete: if isAuthenticated() && hasWorkspaceRole(workspaceId, ['owner', 'admin', 'editor']);
      }

      // Connected Social Accounts
      match /social_accounts/{accountId} {
        allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
        allow create, update, delete: if isAuthenticated() && hasWorkspaceRole(workspaceId, ['owner', 'admin']);
      }

      // Publishing Logs
      match /publishing_logs/{logId} {
        allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
        // Direct writes are blocked; in Spark plan, client-side publishing creates logs
        allow create: if isAuthenticated() && canEditWorkspace(workspaceId);
        allow update, delete: if false;
      }

      // Workspace Activity Audit Logs
      match /activity_logs/{logId} {
        allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
        allow create: if isAuthenticated() && isWorkspaceMember(workspaceId);
        allow update, delete: if false;
      }
    }

    // ─────────────────────────────────────────
    // TRENDS COLLECTION (Global/Cached)
    // ─────────────────────────────────────────
    match /trends/{trendId} {
      allow read: if isAuthenticated();
      // Only system actions can update/write trends
      allow write: if false;
    }

    // ─────────────────────────────────────────
    // SAVED TRENDS COLLECTION
    // ─────────────────────────────────────────
    match /saved_trends/{savedTrendId} {
      // Users can only view and manage their own saved trends
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}

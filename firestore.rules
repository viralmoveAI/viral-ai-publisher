rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // HELPER FUNCTIONS & TYPE VALIDATORS
    // ─────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks if the document ID matches the authenticated user's ID
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper to check if a user profile indicates they are a platform admin
    function isPlatformAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Checks if the user is a member of the workspace
    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    // Fetches the workspace member document
    function getWorkspaceMember(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    // Checks if the user has specific roles in the workspace
    function hasWorkspaceRole(workspaceId, roles) {
      return isWorkspaceMember(workspaceId) &&
        getWorkspaceMember(workspaceId).data.role in roles;
    }

    // Checks if the user is the workspace owner
    function isWorkspaceOwner(workspaceId) {
      return hasWorkspaceRole(workspaceId, ['owner']);
    }

    // Checks if the user has editor/writer permissions in the workspace
    function canEditWorkspace(workspaceId) {
      return hasWorkspaceRole(workspaceId, ['owner', 'admin', 'editor', 'content_creator']);
    }

    // Primitive Type Validators
    function isString(val) {
      return val is string;
    }
    
    function isNumber(val) {
      return val is int || val is float;
    }
    
    function isBool(val) {
      return val is bool;
    }
    
    function isTimestamp(val) {
      return val is timestamp;
    }
    
    function isList(val) {
      return val is list;
    }
    
    function isNullableString(val) {
      return val == null || val is string;
    }

    // ─────────────────────────────────────────
    // USERS COLLECTION
    // ─────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isPlatformAdmin());
      allow create: if isAuthenticated() && isOwner(userId) &&
        request.resource.data.uid == userId &&
        isString(request.resource.data.email) &&
        isString(request.resource.data.displayName) &&
        isNullableString(request.resource.data.photoURL) &&
        request.resource.data.plan in ['free', 'creator', 'pro', 'agency'] &&
        request.resource.data.role in ['user', 'admin'] &&
        isString(request.resource.data.workspaceId) &&
        isTimestamp(request.resource.data.createdAt);
        
      allow update: if isAuthenticated() && isOwner(userId) &&
        // Prevent users from changing their own role or plan
        !('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('plan' in request.resource.data.diff(resource.data).affectedKeys()) &&
        isString(request.resource.data.email) &&
        isString(request.resource.data.displayName) &&
        isNullableString(request.resource.data.photoURL) &&
        isString(request.resource.data.workspaceId);
        
      allow delete: if isPlatformAdmin();

      // User notifications subcollection
      match /notifications/{notificationId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ─────────────────────────────────────────
    // WORKSPACES COLLECTION
    // ─────────────────────────────────────────
    match /workspaces/{workspaceId} {
      // Owners can always read their workspace (needed for the workspaceId backfill query
      // in AuthContext which runs before the membership doc is confirmed).
      allow read: if isAuthenticated() && (
        isWorkspaceMember(workspaceId) ||
        isPlatformAdmin() ||
        resource.data.ownerId == request.auth.uid
      );
      // Anyone logged in can create a workspace (they automatically become the owner in the batch write)
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid &&
        isString(request.resource.data.id) &&
        isString(request.resource.data.name) &&
        isString(request.resource.data.slug) &&
        isNullableString(request.resource.data.description) &&
        isNullableString(request.resource.data.logoURL);
        
      allow update: if isAuthenticated() && hasWorkspaceRole(workspaceId, ['owner', 'admin']) &&
        isString(request.resource.data.name) &&
        isString(request.resource.data.slug) &&
        isNullableString(request.resource.data.description) &&
        isNullableString(request.resource.data.logoURL);
        
      allow delete: if isAuthenticated() && isWorkspaceOwner(workspaceId);

      // Members subcollection (Solves the chicken-and-egg problem)
      match /members/{memberId} {
        allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
        allow create: if isAuthenticated() && (
          // Allow the workspace owner to create their initial membership record
          (request.auth.uid == memberId && request.resource.data.role == 'owner') ||
          // Or allow an existing owner/admin to create a member document
          hasWorkspaceRole(workspaceId, ['owner', 'admin'])
        ) &&
        request.resource.data.userId == memberId &&
        isString(request.resource.data.email) &&
        isString(request.resource.data.displayName) &&
        isNullableString(request.resource.data.photoURL) &&
        request.resource.data.role in ['owner', 'admin', 'editor', 'content_creator', 'viewer'] &&
        request.resource.data.status in ['active', 'invited', 'removed'];
        
        allow update: if isAuthenticated() && hasWorkspaceRole(workspaceId, ['owner', 'admin']) &&
          isString(request.resource.data.email) &&
          isString(request.resource.data.displayName) &&
          isNullableString(request.resource.data.photoURL) &&
          request.resource.data.role in ['owner', 'admin', 'editor', 'content_creator', 'viewer'] &&
          request.resource.data.status in ['active', 'invited', 'removed'];
          
        allow delete: if isAuthenticated() && (
          // Owners and admins can remove members
          hasWorkspaceRole(workspaceId, ['owner', 'admin']) ||
          // Members can remove themselves (leave workspace)
          request.auth.uid == memberId
        );
      }

      // Posts subcollection
      match /posts/{postId} {
        allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
        
        allow create: if isAuthenticated() && canEditWorkspace(workspaceId) &&
          isString(request.resource.data.title) &&
          isString(request.resource.data.caption) &&
          isList(request.resource.data.hashtags) &&
          (request.resource.data.platform == null || request.resource.data.platform in ['TikTok', 'Instagram', 'YouTube', 'Facebook']) &&
          isNullableString(request.resource.data.mediaURL) &&
          (request.resource.data.mediaType == null || request.resource.data.mediaType in ['image', 'video']) &&
          request.resource.data.status in ['Draft', 'Published', 'Failed'] &&
          (!('ytMadeForKids' in request.resource.data) || isBool(request.resource.data.ytMadeForKids)) &&
          (!('ytCategoryId' in request.resource.data) || isString(request.resource.data.ytCategoryId)) &&
          (!('ttPrivacyLevel' in request.resource.data) || request.resource.data.ttPrivacyLevel in ['PUBLIC', 'MUTUAL_FOLLOW_FRIENDS', 'SELF_ONLY']) &&
          (!('ttAllowComment' in request.resource.data) || isBool(request.resource.data.ttAllowComment)) &&
          (!('ttAllowDuet' in request.resource.data) || isBool(request.resource.data.ttAllowDuet)) &&
          (!('ttAllowStitch' in request.resource.data) || isBool(request.resource.data.ttAllowStitch)) &&
          (!('ttIsAigc' in request.resource.data) || isBool(request.resource.data.ttIsAigc)) &&
          (!('ttBrandContent' in request.resource.data) || isBool(request.resource.data.ttBrandContent)) &&
          (!('ttBrandOrganic' in request.resource.data) || isBool(request.resource.data.ttBrandOrganic));
          
        allow update: if isAuthenticated() && canEditWorkspace(workspaceId) &&
          isString(request.resource.data.title) &&
          isString(request.resource.data.caption) &&
          isList(request.resource.data.hashtags) &&
          (request.resource.data.platform == null || request.resource.data.platform in ['TikTok', 'Instagram', 'YouTube', 'LinkedIn', 'Facebook']) &&
          isNullableString(request.resource.data.mediaURL) &&
          (request.resource.data.mediaType == null || request.resource.data.mediaType in ['image', 'video']) &&
          request.resource.data.status in ['Draft', 'Published', 'Failed'] &&
          (!('ytMadeForKids' in request.resource.data) || isBool(request.resource.data.ytMadeForKids)) &&
          (!('ytCategoryId' in request.resource.data) || isString(request.resource.data.ytCategoryId)) &&
          (!('ttPrivacyLevel' in request.resource.data) || request.resource.data.ttPrivacyLevel in ['PUBLIC', 'MUTUAL_FOLLOW_FRIENDS', 'SELF_ONLY']) &&
          (!('ttAllowComment' in request.resource.data) || isBool(request.resource.data.ttAllowComment)) &&
          (!('ttAllowDuet' in request.resource.data) || isBool(request.resource.data.ttAllowDuet)) &&
          (!('ttAllowStitch' in request.resource.data) || isBool(request.resource.data.ttAllowStitch)) &&
          (!('ttIsAigc' in request.resource.data) || isBool(request.resource.data.ttIsAigc)) &&
          (!('ttBrandContent' in request.resource.data) || isBool(request.resource.data.ttBrandContent)) &&
          (!('ttBrandOrganic' in request.resource.data) || isBool(request.resource.data.ttBrandOrganic));
          
        allow delete: if isAuthenticated() && hasWorkspaceRole(workspaceId, ['owner', 'admin', 'editor']);
      }

      // Connected Social Accounts
      match /social_accounts/{accountId} {
        allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
        
        allow create, update: if isAuthenticated() && hasWorkspaceRole(workspaceId, ['owner', 'admin']) &&
          isString(request.resource.data.id) &&
          isString(request.resource.data.workspaceId) &&
          request.resource.data.platform in ['facebook', 'instagram', 'tiktok', 'youtube'] &&
          isString(request.resource.data.accountName) &&
          isString(request.resource.data.accountId) &&
          isString(request.resource.data.accessToken) &&
          (!('refreshToken' in request.resource.data) || isString(request.resource.data.refreshToken)) &&
          (!('scopes' in request.resource.data) || isList(request.resource.data.scopes)) &&
          (request.resource.data.tokenExpiresAt == null || isTimestamp(request.resource.data.tokenExpiresAt)) &&
          isNullableString(request.resource.data.profilePictureURL) &&
          (request.resource.data.followerCount == null || isNumber(request.resource.data.followerCount));
          
        allow delete: if isAuthenticated() && hasWorkspaceRole(workspaceId, ['owner', 'admin']);
      }

      // Publishing Logs
      match /publishing_logs/{logId} {
        allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
        
        // Direct writes are allowed for workspace creators
        allow create: if isAuthenticated() && canEditWorkspace(workspaceId) &&
          isString(request.resource.data.id) &&
          isString(request.resource.data.workspaceId) &&
          isString(request.resource.data.postId) &&
          isString(request.resource.data.postTitle) &&
          isString(request.resource.data.triggeredBy) &&
          request.resource.data.platform in ['facebook', 'instagram', 'tiktok', 'youtube'] &&
          isString(request.resource.data.socialAccountId) &&
          isString(request.resource.data.accountName) &&
          request.resource.data.status in ['success', 'failed', 'pending'] &&
          (!('publishStatus' in request.resource.data) || request.resource.data.publishStatus in ['success', 'failed', 'processing']) &&
          isNullableString(request.resource.data.platformPostId) &&
          isNullableString(request.resource.data.platformPostUrl) &&
          isNullableString(request.resource.data.errorCode) &&
          isNullableString(request.resource.data.errorMessage) &&
          isTimestamp(request.resource.data.attemptedAt) &&
          (request.resource.data.completedAt == null || isTimestamp(request.resource.data.completedAt)) &&
          (request.resource.data.durationMs == null || isNumber(request.resource.data.durationMs)) &&
          isBool(request.resource.data.isMock) &&
          (!('likeCount' in request.resource.data) || isNumber(request.resource.data.likeCount)) &&
          (!('commentCount' in request.resource.data) || isNumber(request.resource.data.commentCount)) &&
          (!('viewCount' in request.resource.data) || isNumber(request.resource.data.viewCount)) &&
          (!('shareCount' in request.resource.data) || isNumber(request.resource.data.shareCount)) &&
          (!('lastSyncedAt' in request.resource.data) || isTimestamp(request.resource.data.lastSyncedAt));
          
        // Allow updates to publishStatus, completedAt, and analytics counts
        allow update: if isAuthenticated() && isWorkspaceMember(workspaceId) &&
          request.resource.data.status in ['success', 'failed', 'pending'] &&
          (!('publishStatus' in request.resource.data) || request.resource.data.publishStatus in ['success', 'failed', 'processing']) &&
          (request.resource.data.completedAt == null || isTimestamp(request.resource.data.completedAt)) &&
          (request.resource.data.durationMs == null || isNumber(request.resource.data.durationMs)) &&
          (!('likeCount' in request.resource.data) || isNumber(request.resource.data.likeCount)) &&
          (!('commentCount' in request.resource.data) || isNumber(request.resource.data.commentCount)) &&
          (!('viewCount' in request.resource.data) || isNumber(request.resource.data.viewCount)) &&
          (!('shareCount' in request.resource.data) || isNumber(request.resource.data.shareCount)) &&
          (!('lastSyncedAt' in request.resource.data) || isTimestamp(request.resource.data.lastSyncedAt));
          
        allow delete: if false;
      }

      // Workspace Activity Audit Logs
      match /activity_logs/{logId} {
        allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
        allow create: if isAuthenticated() && isWorkspaceMember(workspaceId);
        allow update, delete: if false;
      }
    }

    // ─────────────────────────────────────────
    // TRENDS COLLECTION (Global/Cached)
    // ─────────────────────────────────────────
    match /trends/{trendId} {
      allow read: if isAuthenticated();
      // Only system actions/admins can update/write trends
      allow write: if isPlatformAdmin() &&
        isString(request.resource.data.id) &&
        isString(request.resource.data.topic) &&
        isNumber(request.resource.data.trendScore) &&
        isString(request.resource.data.growthRate) &&
        request.resource.data.viralProbability in ['High', 'Medium', 'Low'] &&
        isList(request.resource.data.contentAngles);
    }

    // ─────────────────────────────────────────
    // SAVED TRENDS COLLECTION
    // ─────────────────────────────────────────
    match /saved_trends/{savedTrendId} {
      // Users can only view and manage their own saved trends
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
